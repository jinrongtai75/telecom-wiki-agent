# ── 필수 설정 ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars

# ── LLM 게이트웨이 ─────────────────────────────────────────────────────────────
JIHYE_GATEWAY_URL=https://jihye.ucube.lgudax.cool/api/bedrock/us.anthropic.claude-sonnet-4-6

# ── 데이터베이스 ──────────────────────────────────────────────────────────────
# 로컬 SQLite (기본값)
DATABASE_URL=sqlite:///./data/telecom.db
# 운영 PostgreSQL (Supabase)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── 로컬 스토리지 경로 ────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma
DOCUMENTS_PATH=./data/documents
IMAGES_PATH=./data/images
MARKDOWNS_PATH=./data/markdowns

# ── Supabase Storage (설정 시 로컬 파일시스템 대신 사용) ──────────────────────
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=telecom-wiki

# ── 서버 설정 ─────────────────────────────────────────────────────────────────
BACKEND_PORT=8001
# 실제 배포된 프론트엔드 URL로 교체
CORS_ORIGINS=http://localhost:5173,http://localhost:1024

# ── 검색 파라미터 ─────────────────────────────────────────────────────────────
RELEVANCE_THRESHOLD=0.7
SEARCH_TOP_K=10
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
