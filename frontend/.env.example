# ── Wiki Agent 백엔드 URL ─────────────────────────────────────────────────────
# 로컬: 비워두면 Vite 프록시(/api → localhost:8001)가 자동 처리
# 운영: 실제 배포된 백엔드 URL 입력 (예: https://wiki-backend.railway.app)
VITE_API_URL=https://telecom-wiki-agent-production.up.railway.app

# ── 전처리 도구 URL ───────────────────────────────────────────────────────────
# 로컬: http://localhost:1024
# 운영: 실제 배포된 전처리 프론트엔드 URL
VITE_PREPROCESSOR_URL=http://localhost:1024
